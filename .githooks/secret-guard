#!/usr/bin/env bash
set -euo pipefail

MODE="${1:-}"
REMOTE_NAME="${2:-origin}"
ZERO_SHA="0000000000000000000000000000000000000000"
SECRET_REGEX='BEGIN [A-Z0-9 ]*PRIVATE KEY|ghp_[A-Za-z0-9]{36,}|github_pat_[A-Za-z0-9_]{20,}|AKIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35}|xox[baprs]-[A-Za-z0-9-]{10,}|(SB-)?Mid-(server|client)-[A-Za-z0-9_-]+|sk_(live|test)_[A-Za-z0-9]{16,}'
VIOLATIONS=0

print_header() {
  cat >&2 <<'EOF'
Blocked by repository secret guard.
EOF
}

print_footer() {
  cat >&2 <<'EOF'

Next step:
- Keep secrets only in local `.env` files.
- Commit only `.env.example`.
- If this branch predates the cleanup, create a fresh branch from `origin/main` and cherry-pick safe commits.
EOF
}

is_allowed_example() {
  case "$1" in
    .env.example|*/.env.example|.env.*.example|*/.env.*.example)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

is_blocked_path() {
  local path="$1"

  if is_allowed_example "$path"; then
    return 1
  fi

  case "$path" in
    .env|*/.env|.env.*|*/.env.*)
      return 0
      ;;
    *.pem|*.key|*.p12|*.pfx|*.jks|*.keystore|id_rsa|*/id_rsa|id_ed25519|*/id_ed25519)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

check_paths_from_stream() {
  local scope="$1"
  local path
  local found=0

  while IFS= read -r path; do
    [ -z "$path" ] && continue
    if is_blocked_path "$path"; then
      if [ "$found" -eq 0 ]; then
        print_header
        printf 'Blocked %s because these paths look sensitive:\n' "$scope" >&2
      fi
      printf '%s\n' "  - $path" >&2
      found=1
      VIOLATIONS=1
    fi
  done

  if [ "$found" -eq 1 ]; then
    print_footer
  fi
}

check_added_lines() {
  local scope="$1"
  local diff_text="$2"
  local matches

  matches="$(printf '%s\n' "$diff_text" | grep -E '^\+[^+]' | grep -En "$SECRET_REGEX" | sed -n '1,20p' || true)"

  if [ -n "$matches" ]; then
    print_header
    printf 'Blocked %s because secret-like content was detected in added lines:\n' "$scope" >&2
    printf '%s\n' "$matches" >&2
    print_footer
    VIOLATIONS=1
  fi
}

check_pre_commit() {
  local staged_files
  local diff_text

  staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
  [ -z "$staged_files" ] && return 0

  check_paths_from_stream "this commit" <<<"$staged_files"
  diff_text="$(git diff --cached --no-color --text --unified=0)"
  check_added_lines "this commit" "$diff_text"
}

check_commit_object() {
  local commit="$1"
  local changed_files
  local diff_text

  changed_files="$(git diff-tree --no-commit-id --name-only -r "$commit")"
  if [ -n "$changed_files" ]; then
    check_paths_from_stream "pushing commit $commit" <<<"$changed_files"
  fi

  diff_text="$(git show --no-color --format= --unified=0 "$commit")"
  check_added_lines "pushing commit $commit" "$diff_text"
}

check_pre_push() {
  local local_ref local_sha remote_ref remote_sha
  local commit
  local commit_list

  while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "${local_ref:-}" ] && continue

    if [ "$local_sha" = "$ZERO_SHA" ]; then
      continue
    fi

    if [ "$remote_sha" = "$ZERO_SHA" ]; then
      commit_list="$(git rev-list "$local_sha" --not --remotes="$REMOTE_NAME")"
    else
      commit_list="$(git rev-list "${remote_sha}..${local_sha}")"
    fi

    for commit in $commit_list; do
      check_commit_object "$commit"
    done
  done
}

case "$MODE" in
  pre-commit)
    check_pre_commit
    ;;
  pre-push)
    check_pre_push
    ;;
  *)
    printf 'Usage: %s {pre-commit|pre-push} [remote-name]\n' "$0" >&2
    exit 1
    ;;
esac

exit "$VIOLATIONS"
